  "unit_conversion_logic": {
    "description": "IU/mcg → mg 변환 (Step 2 Lambda)",
    "rules": [
      {
        "unit": "mg",
        "conversion": "그대로 (1x)"
      },
      {
        "unit": "mcg / µg / μg",
        "conversion": "× unit_cache['mcg'] (기본값: 0.001)",
        "example": "100 mcg = 100 × 0.001 = 0.1 mg"
      },
      {
        "unit": "IU",
        "conversion": "× unit_cache[nutrient_name_ko] (영양소별 상이)",
        "example": {
          "비타민D": "1000 IU × 0.000025 = 0.025 mg",
          "비타민A": "1000 IU × 0.000030 = 0.030 mg"
        }
      }
    ],
    "implementation": "/lambdas/action_nutrient_calc/handler.py - to_mg() 함수"
  },
