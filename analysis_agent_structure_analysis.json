  "key_business_rules": {
    "step1_analysis": {
      "title": "필요 영양소 분석 기준",
      "rules": [
        "건강검진 수치 중 저/고/경계값 항목 파악",
        "의약품-영양소 상호작용 검토 (KB 기반)",
        "섭취 목적에 맞는 영양소 우선 제안",
        "한국 영양소 기준 섭취량(KDRI) 기반",
        "약물 상호작용 주의 영양소 → required_nutrients 제외, key_concerns에 명시",
        "재분석 시: new_purpose 우선, 없으면 previous_analysis에서 파악"
      ]
    },
    "step1_summary": {
      "title": "평가(summary) 작성 지침",
      "rules": [
        "overall_assessment: 7문장 이상, 검진 수치 구체적 언급, 공감 어조, 긍정적 메시지",
        "key_concerns: '[약물명] 복용 중 [영양소] [구체적 주의내용]' 형식 (뭉뚱그린 표현 금지)",
        "lifestyle_notes: 식품 예시, 운동 빈도, 수면-영양소 연관성, 복용 타이밍 포함",
        "risk_warnings: 의약품 상호작용/과잉섭취 경고 (없으면 빈 배열)"
      ]
    },
    "step3_recommendation": {
      "title": "영양제 추천 기준",
      "rules": [
        "제공된 제품 목록에서만 추천 (임의 생성 금지)",
