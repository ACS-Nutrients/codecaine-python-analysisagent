AWS_REGION=ap-northeast-2

# LLM 제공자: "openai" / "anthropic" / "bedrock"
LLM_PROVIDER=openai

# OpenAI API 사용 시
OPENAI_API_KEY=

# Anthropic API 사용 시
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL_ID=claude-sonnet-4-5

# Bedrock 사용 시 (운영)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Lambda 함수명
LAMBDA_FUNCTION_NAME=action-nutrient-calc

# Knowledge Base 설정 (Chroma DB는 이미지에 포함)
KB_LOCAL_PATH=/app/lpi_vector_db
KB_COLLECTION_NAME=lpi_interactions
KB_TOP_K=3

# 로컬 테스트 시에만 설정
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
